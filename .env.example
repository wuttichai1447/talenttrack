# Database
# SQLite (default for local development)
DATABASE_URL="file:./dev.db"
# For Postgres (production), e.g. Neon/Supabase:
# DATABASE_URL="postgresql://user:password@host:5432/talenttrack"

# Anthropic Claude API key — used for Module 1 (Resume Screener) and Module 4 (AI Reports)
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# Optional: override Claude model (defaults to claude-sonnet-4-6 in code)
# ANTHROPIC_MODEL="claude-sonnet-4-6"
